# Keep the build context (and image) small and reproducible.
.git
.gitignore
**/__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
*.pdf

# Components not needed by the web service image
macapp/
tests/
examples/
docs/
*.md
!README.md
Dockerfile
.dockerignore
docker-compose.yml
